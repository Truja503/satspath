# ─────────────────────────────────────────────────────────────────────────────
# SatsPath — Environment variables reference
#
# Copy this file to .env and fill in values for your deployment.
# .env is in .gitignore and .dockerignore — it must never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── SatsPath CLI ─────────────────────────────────────────────────────────────

# Directory where .satspath/ registry and key state is stored inside the
# container. This path should be backed by a named Docker volume.
SATSPATH_DATA_DIR=/data

# Rust log level (trace | debug | info | warn | error)
# RUST_LOG=satspath=info

# ── ARK Bridge ───────────────────────────────────────────────────────────────

# Port the JSON-RPC bridge listens on (internal only — not exposed publicly).
ARK_BRIDGE_PORT=3000

# Node environment
NODE_ENV=production
